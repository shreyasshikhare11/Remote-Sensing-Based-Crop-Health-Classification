/**
 * Advanced Crop Health Analytics & Modeling Framework
 * * Core Diagnostics & Additions:
 * 1. Multi-Index Time-Series Dashboard: NDVI (Vigor), EVI (Biomass), and SAVI (Young Crops).
 * 2. Canopy Hydration Monitoring: NDWI (Normalized Difference Water Index) to track moisture stress.
 * 3. Meteorological Correlation: Daily ERA5-Land precipitation charting (global coverage) over the temporal window.
 * 4. Spatial-Temporal Climatological Anomalies (Z-Score): Computes pixel-wise 2026 crop performance
 * deviations relative to a 5-year historical baseline (2020-2025).
 * 5. Predictive Linear Modeling & Unsupervised Spatial ML zoning.
 */

// --- 1. SETUP ---
var USER_AOI =  ee.Geometry.Polygon([[[-0.29993538836850187, 51.44612676706183],
          [-0.30523436112362745, 51.434637508856255],
          [-0.2960018030216327, 51.429196960669024],
          [-0.29226313328399645, 51.429535365104655],
          [-0.2861612052290208, 51.421007523891646],
          [-0.25917251850617884, 51.43558795802102],
          [-0.24189678199908027, 51.442449269434654],
          [-0.2466474867856605, 51.448340834212786],
          [-0.25483269412076126, 51.45145044786903],
          [-0.25672096926724564, 51.45401778809462],
          [-0.26307244021451126, 51.45658498394277],
          [-0.26925224978482376, 51.45690587327239],
          [-0.27199883181607376, 51.458403326983436],
          [-0.27783531863248, 51.458082448181074],
          [-0.28367180544888626, 51.461611990938415],
          [-0.28332848269498, 51.456691947303305],
          [-0.2955164404586519, 51.45005974496322]]]); 
var S2_COLLECTION = ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED');

Map.centerObject(USER_AOI, 13.5);

// --- 2. CLOUD MASKING & SCALING ---
function maskS2clouds(image) {
  var qa = image.select('QA60');
  var cloudBitMask = 1 << 10;
  var cirrusBitMask = 1 << 11;
  var mask = qa.bitwiseAnd(cloudBitMask).eq(0)
      .and(qa.bitwiseAnd(cirrusBitMask).eq(0));
  
  var reflectiveBands = image.select(['B2', 'B3', 'B4', 'B5', 'B6', 'B7', 'B8', 'B8A', 'B11', 'B12']).divide(10000);
  return image.addBands(reflectiveBands, null, true).updateMask(mask);
}

// --- 3. EXPANDED BIOMASS, HEALTH, SOIL & WATER INDICES ---
var addIndices = function(img) {
  // NDVI (Vigor)
  var ndvi = img.normalizedDifference(['B8', 'B4']).rename('NDVI');
  
  // EVI (Biomass Proxy)
  var evi = img.expression(
    '2.5 * ((NIR - RED) / (NIR + 6 * RED - 7.5 * BLUE + 1))', {
      'NIR': img.select('B8'),
      'RED': img.select('B4'),
      'BLUE': img.select('B2')
  }).rename('EVI').clamp(-1.0, 1.0);
  
  // SAVI (Soil Adjusted Vegetation Index)
  var savi = img.expression(
    '((NIR - RED) * (1 + L)) / (NIR + RED + L)', {
      'NIR': img.select('B8'),
      'RED': img.select('B4'),
      'L': 0.5
  }).rename('SAVI').clamp(-1.0, 1.0);
  
  // NDWI (Canopy Water Content - NIR and SWIR1)
  var ndwi = img.normalizedDifference(['B8', 'B11']).rename('NDWI').clamp(-1.0, 1.0);
  
  return img.addBands([ndvi, evi, savi, ndwi]);
};

// --- 4. TIME SERIES GENERATION & GRAPHING ---
var tsCollection = S2_COLLECTION
  .filterBounds(USER_AOI)
  .filterDate('2020-01-01', '2026-06-18')
  .map(maskS2clouds)
  .map(addIndices)
  .map(function(img) {
    var count = img.select('NDVI').reduceRegion({
      reducer: ee.Reducer.count(),
      geometry: USER_AOI,
      scale: 30,
      maxPixels: 1e9
    }).get('NDVI');
    return img.set('valid_pixels', count);
  })
  .filter(ee.Filter.gt('valid_pixels', 0));

// Chart 1: Average Crop Health (NDVI) Trend
