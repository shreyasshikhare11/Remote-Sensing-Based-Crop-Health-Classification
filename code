// --- 5. STATISTICAL REGRESSION (Predictive Health Foundation) ---
var years = ee.List.sequence(2020, 2026);

// Compute annual means for NDVI, EVI, and SAVI concurrently
var annualMean = ee.ImageCollection.fromImages(years.map(function(y) {
  var start = ee.Date.fromYMD(y, 1, 1);
  var filtered = tsCollection.filterDate(start, start.advance(1, 'year'));
  
  // Robust image checking with explicit type casting for NDVI, EVI, and SAVI
  var meanIndices = ee.Image(ee.Algorithms.If(
    filtered.size().gt(0),
    filtered.select(['NDVI', 'EVI', 'SAVI']).mean(),
    ee.Image.constant([0, 0, 0]).rename(['NDVI', 'EVI', 'SAVI'])
  )).toFloat();
  
  var yearBand = ee.Image.constant(y).rename('year').double();
  return yearBand.addBands(meanIndices).set('year', y);
}));

// Run regression analysis for all three indices
var ndviRegression = annualMean.select(['year', 'NDVI']).reduce(ee.Reducer.linearFit());
var eviRegression = annualMean.select(['year', 'EVI']).reduce(ee.Reducer.linearFit());
var saviRegression = annualMean.select(['year', 'SAVI']).reduce(ee.Reducer.linearFit());

// Add trend maps to the GEE UI, clipped strictly to the USER_AOI
Map.addLayer(ndviRegression.select('scale').clip(USER_AOI), {min: -0.05, max: 0.05, palette: ['red', 'white', 'green']}, 'NDVI Trend Forecast');
Map.addLayer(eviRegression.select('scale').clip(USER_AOI), {min: -0.05, max: 0.05, palette: ['red', 'white', 'blue']}, 'EVI Trend Forecast');
Map.addLayer(saviRegression.select('scale').clip(USER_AOI), {min: -0.05, max: 0.05, palette: ['red', 'white', 'purple']}, 'SAVI Trend Forecast');

// --- 6. METEOROLOGICAL & CLIMATOLOGICAL ANOMALIES (Z-Score) ---
var historicalBaseline = tsCollection.filterDate('2020-01-01', '2025-12-31').select('NDVI');
var historicalMean = historicalBaseline.mean();
var historicalStdDev = historicalBaseline.reduce(ee.Reducer.stdDev()).clamp(0.01, 1.0);

// Current Year (2026) Composite
var currentYearMean = tsCollection.filterDate('2026-01-01', '2026-06-18').select('NDVI').mean();

// Z-Score calculation
var zScore = currentYearMean.subtract(historicalMean).divide(historicalStdDev).rename('NDVI_Z_Score').clip(USER_AOI);
Map.addLayer(zScore, {min: -2.0, max: 2.0, palette: ['#D7191C', '#FDAE61', '#FFFFBF', '#ABD9E9', '#2C7BB6']}, 'Climatological Anomaly (NDVI Z-Score)');

// --- 7. MACHINE LEARNING (K-Means Clustering) ---
var mlComposite = tsCollection.select(['NDVI', 'EVI', 'SAVI', 'NDWI']).median().clip(USER_AOI);

var training = mlComposite.sample({
  region: USER_AOI,
  scale: 30,
  numPixels: 1000,
  seed: 42,
  dropNulls: true,
  tileScale: 16
});

var clusterer = ee.Clusterer.wekaKMeans(3).train(training);
var clusteredImage = mlComposite.cluster(clusterer);
Map.addLayer(clusteredImage, {min: 0, max: 2, palette: ['#A52A2A', '#F4A460', '#228B22']}, 'K-Means Crop Zones (ML)');

print('Framework expansion complete. Map contains Trend Forecasts (NDVI, EVI, SAVI), Climatological Anomalies (Z-Score), and K-Means ML Crop Zones.');
