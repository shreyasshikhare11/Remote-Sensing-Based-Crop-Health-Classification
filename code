// Chart 5: Environmental Driver - ERA5-Land Daily Precipitation (Global Coverage)
// Replaced CHIRPS with ECMWF/ERA5_LAND/DAILY_AGGR and scaled from meters to millimeters (mm)
var precipCollection = ee.ImageCollection('ECMWF/ERA5_LAND/DAILY_AGGR')
  .filterBounds(USER_AOI)
  .filterDate('2020-01-01', '2026-06-18')
  .map(function(img) {
    var precipMm = img.select('total_precipitation_sum').multiply(1000).rename('precipitation');
    return img.addBands(precipMm, null, true).select('precipitation');
  });

var precipChart = ui.Chart.image.series({
  imageCollection: precipCollection,
  region: USER_AOI,
  reducer: ee.Reducer.sum(),
  scale: 9000, // ERA5-Land resolution is ~9km
  xProperty: 'system:time_start'
}).setOptions({
  title: 'Environmental Driver: Daily Local Precipitation (ERA5-Land)',
  vAxis: {title: 'Rainfall (mm)'},
  hAxis: {title: 'Date'},
  colors: ['#4285F4']
});

// Output all diagnostics dashboard graphs to Console
print(ndviChart);
